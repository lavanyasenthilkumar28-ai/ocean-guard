<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF7FF">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:text="AquaWatch Admin"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvAdminEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="admin@gmail.com"
            android:textColor="#666"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ===== CONTENT ===== -->
    <ScrollView
        android:layout_below="@id/header"
        android:layout_above="@id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ACTIVE USERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:text="Active Users"
                    android:textSize="14sp"
                    android:textColor="#555"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvUserCount"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- EMERGENCY STATUS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:text="Emergency Status"
                    android:textSize="14sp"
                    android:textColor="#555"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvEmergency"
                    android:text="NO EMERGENCY"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- LAST LOCATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:orientation="vertical">

                <TextView
                    android:text="Last Known Location"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvLastLocation"
                    android:text="Waiting for data..."
                    android:textColor="#555"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnLiveMonitor"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="LIVE EMERGENCY MONITOR"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#D32F2F"
                    android:layout_marginTop="16dp"/>
                <Button
                    android:id="@+id/btnSOSHistory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="SOS HISTORY"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#B71C1C"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnResolve"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_below="@id/map"
                    android:backgroundTint="#4CAF50"
                    android:text="RESOLVE EMERGENCY"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>



        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAV ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"/>

        <ImageView
            android:id="@+id/navPeople"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="24dp"
            android:src="@drawable/ic_people"/>

        <ImageView
            android:id="@+id/navLogout"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="24dp"
            android:src="@drawable/ic_logout"/>
    </LinearLayout>

</RelativeLayout>